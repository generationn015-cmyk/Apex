# ============================================================
#  APEX Trading Bot — Secrets Template
#  Copy this to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# ── Toobit ─────────────────────────────────────────────────
TOOBIT_API_KEY=your_api_key_here
TOOBIT_API_SECRET=your_api_secret_here

# ── Hyperliquid ─────────────────────────────────────────────
# Your EVM wallet address (0x...)
HYPERLIQUID_WALLET=0x...
# Private key for signing orders — keep this VERY secret
HYPERLIQUID_PRIVATE_KEY=0x...

# ── Lighter.xyz ─────────────────────────────────────────────
LIGHTER_WALLET=0x...
LIGHTER_PRIVATE_KEY=0x...

# ── Polymarket ───────────────────────────────────────────────
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=0x...

# ── Telegram Alerts ──────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → get token
# 2. Message @userinfobot to get your chat_id
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=123456789
