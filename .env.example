# APEX — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Telegram
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Twelve Data (market data)
TWELVE_DATA_KEY_1=your_key_here
TWELVE_DATA_KEY_2=your_backup_key_here

# Lighter.xyz Exchange (required for live trading)
# Get keys at: app.lighter.xyz → API Keys
LIGHTER_API_KEY_ID=
LIGHTER_API_KEY_SECRET=

# Anthropic (optional — Claude AI signal review)
ANTHROPIC_API_KEY=

# Polymarket (optional — live betting)
POLY_PRIVATE_KEY=

# Trading mode: "paper" (safe default) or "live" (real money)
TRADING_MODE=paper
